# ─────────────────────────────────────────────────────────────
# Sacci Brand Hub — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Application
APP_NAME="Sacci Brand Hub"
APP_ENV=local          # local | development | staging | production
APP_BASE=              # Leave empty if app is at domain root (e.g. sacci.site/)
                       # Set to subfolder path if hosted in subdirectory (e.g. /hub)

# Database (MySQL 8)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=sacci_brand_hub
DB_USERNAME=root
DB_PASSWORD=

# Mail (PHPMailer / SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@sacci.site
MAIL_PASSWORD=
MAIL_FROM=no-reply@sacci.site  # Defaults to MAIL_USERNAME if not set

# Airtable (optional — used by ActionController)
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_ACTIONS_TABLE=
AIRTABLE_ACTIONS_VIEW=
